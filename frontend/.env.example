# 复制本文件为 .env 后再本地修改（.env 已被 gitignore，勿提交密钥）
# Copy to .env:  cp .env.example .env   (PowerShell: Copy-Item .env.example .env)

# ---------------------------------------------------------------------------
# Sprint 2 联调默认：关闭 MSW，XHR 直连后端 http://localhost:8080/api/v1
# Integration default (Sprint 2): MSW off; requests go to real API.
# ---------------------------------------------------------------------------
VITE_USE_MOCK=false

# 仅在没有后端、或纯前端 UI 调试时，改为 true 以启用 MSW（见 FRONTEND_SPEC.md §4）
# Set to true only for offline UI work or when backend is unavailable.
# VITE_USE_MOCK=true
