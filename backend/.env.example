PORT=8080
JWT_SECRET=uaad-super-secret-key-2026
APP_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=uaad

# MySQL 连接池（服务端 / go test / seed 共用 config.Load()）
# DB_CONN_MAX_LIFETIME 为 Go time.ParseDuration 格式，如 1h、30m
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h

# 注册接口限流（仅 /api/v1/auth/register）。默认约每分钟 5 次、突发 5。
# 本地批量执行 gen_jmeter_data -count 1000 时可临时放宽，例如：
# REG_RATE_LIMIT_PER_MIN=120
# REG_RATE_LIMIT_BURST=40
# 用完请恢复或勿提交含大值的 .env。

# CORS 白名单（逗号分隔）。开发态留空时默认放开，生产态留空时默认拒绝跨域。
# 示例：
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://uaad.example.com

# Redis 库存一致性巡检频率（分钟）。默认每 10 分钟巡检并自动修复漂移。
STOCK_RECONCILE_MINUTES=10
